{
  "preset": "ts-jest",
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transformIgnorePatterns": [],
  "moduleNameMapper": {
    "^@apcinema/shared$": "<rootDir>/../common/src/index.ts",
    "^@nestjs/common$": "<rootDir>/node_modules/@nestjs/common",
    "^@nestjs/core$": "<rootDir>/node_modules/@nestjs/core",
    "^@nestjs/jwt$": "<rootDir>/node_modules/@nestjs/jwt",
    "^src/(.*)$": "<rootDir>/src/$1",
    "^(\\.\\.?/.+)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/test/tsconfig.e2e.json"
      }
    ]
  }
}
